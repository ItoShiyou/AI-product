{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/og",
      "dest": "/api/og.js"
    },
    {
      "src": "/api/share",
      "dest": "/api/share.js"
    },
    {
      "src": "/api/og-image",
      "dest": "/api/og-image.js"
    },
    {
      "src": "/share",
      "dest": "/share.html"
    },
    {
      "src": "/og-card",
      "dest": "/og-card.html"
    },
    {
      "src": "/job-master.json",
      "dest": "/job-master.json"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
    ]
}
