{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        "meta": {
          ".read": "auth != null",
          ".write": false
        },
        "public": {
          ".read": "auth != null",
          ".write": false
        },
        "players": {
          "$uid": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "actionQueue": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "private": {
      "$roomId": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": false
        }
      }
    }
  }
}
